{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "python manage.py migrate --noinput && gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --workers 4 --timeout 120",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}